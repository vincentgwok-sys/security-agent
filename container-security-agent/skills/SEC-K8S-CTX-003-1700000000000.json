{
  "skillId": "SEC-K8S-CTX-003",
  "skillName": "系统调用与内核攻击面",
  "versionTimestamp": 1700000000000,
  "riskLevel": "HIGH",
  "description": "检测容器是否可执行高危系统调用（如 unshare、nsenter），以及 seccomp 安全配置是否生效，评估其对内核的攻击面大小。",
  "evolutionCount": 0,
  "reportMetadata": {
    "remediationFocus": "指导用户配置 Kubernetes 的 seccompProfile（RuntimeDefault 或自定义 seccomp 配置文件），限制容器可用的系统调用集合，降低内核漏洞利用风险。"
  },
  "executionContexts": [
    {
      "contextId": "linux-debian-ubuntu-standard",
      "environmentFingerprint": {
        "osType": "linux",
        "osFlavors": ["debian", "ubuntu"],
        "shellType": "bash",
        "requiredTools": ["cat", "grep", "unshare", "nsenter"],
        "optionalTools": ["strace", "seccomp-tools"],
        "minKernelVersion": "3.10.0",
        "arch": ["amd64", "arm64"]
      },
      "envCheckCommands": [
        "uname -s",
        "cat /etc/os-release 2>/dev/null | grep '^ID=' | head -1",
        "which cat grep unshare nsenter 2>/dev/null",
        "echo $SHELL",
        "uname -r",
        "uname -m"
      ],
      "executionLogic": {
        "expectedBehavior": "如果 seccomp 配置正常，nsenter 和 unshare 等系统调用应被拦截（Operation not permitted 或 EPERM）。/proc/1/status 中的 Seccomp 字段应为 2（strict）或非零值。",
        "detectionCommands": [
          "cat /proc/1/status | grep -E '^Seccomp:'",
          "unshare -U /bin/sh -c 'echo escaped' 2>&1",
          "nsenter --mount=/proc/1/ns/mnt -- /bin/sh -c 'echo escaped' 2>&1",
          "cat /proc/sys/kernel/unprivileged_userns_clone 2>&1",
          "cat /proc/self/status | grep -E 'CapEff|NoNewPrivs'"
        ]
      },
      "evolvedFrom": null,
      "evolvedAt": null,
      "deprecated": false
    },
