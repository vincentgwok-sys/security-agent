{
  "skillId": "SEC-K8S-CTX-003",
  "skillName": "系统调用与内核攻击面",
  "versionTimestamp": 1700000000000,
  "riskLevel": "HIGH",
  "description": "检测容器是否可执行高危系统调用（如 unshare、nsenter、ptrace），以及 seccomp 安全配置是否生效，评估其对内核的攻击面大小。",
  "evolutionCount": 0,
  "reportMetadata": {
    "remediationFocus": "指导用户配置 Kubernetes 的 seccompProfile（RuntimeDefault 或自定义 seccomp 配置文件），限制容器可用的系统调用集合，降低内核漏洞利用风险。"
  },
  "executionContexts": [
    {
      "contextId": "linux-debian-ubuntu-standard",
      "environmentFingerprint": {
        "osType": "linux",
        "osFlavors": ["debian", "ubuntu"],
        "shellType": "bash",
        "requiredTools": ["cat", "grep", "nsenter"],
        "optionalTools": ["unshare", "strace", "capsh", "bpftool"],
        "minKernelVersion": "3.10.0",
        "arch": ["amd64", "arm64"]
      },
      "envCheckCommands": [
        "uname -s",
        "cat /etc/os-release 2>/dev/null | grep -E '^ID=|^VERSION_ID=' | head -3",
        "which cat grep nsenter unshare strace capsh 2>/dev/null",
        "echo $SHELL",
        "uname -r",
        "uname -m"
      ],
      "executionLogic": {
        "expectedBehavior": "【判定硬规则】① nsenter/unshare exit≠0+stderr含Operation not permitted/Permission denied/EPERM=不允许的操作=PASS(安全)。② nsenter/unshare exit=0+输出ESCAPED=FAIL(逃逸成功)。③ Seccomp=2或1=PASS, Seccomp=0=FAIL。④ NoNewPrivs=1=PASS。⑤ CapEff=0000000000000000(全零)=PASS。⑥ /proc/sys/kernel/unprivileged_userns_clone 在 kernel 5.10+上可能不存在(file not found)=PASS(非漏洞)。⑦ /proc/sys/user/max_user_namespaces 的值是宿主机全局资源上限(默认约100万)，高值是正常默认值，仅作信息收集，绝不判FAIL。真正的 user namespace 检测依据是 unshare -U 命令的结果——若该命令已被拒绝(PASS)，则无论 max_user_namespaces 值多大容器都是安全的。⑧ exit=127=工具不存在=PASS。",
        "detectionCommands": [
          "cat /proc/1/status 2>&1 | grep -E '^Seccomp:'",
          "nsenter --mount=/proc/1/ns/mnt -- /bin/sh -c 'echo ESCAPED_TO_HOST_MNT_NS' 2>&1",
          "unshare -U /bin/sh -c 'echo ESCAPED_VIA_USERNS' 2>&1",
          "cat /proc/sys/kernel/unprivileged_userns_clone 2>&1; cat /proc/sys/user/max_user_namespaces 2>&1; echo 'USRNS_INFO_ONLY'",
          "cat /proc/self/status 2>&1 | grep -E 'CapEff|NoNewPrivs|Seccomp'"
        ]
      },
      "evolvedFrom": null,
      "evolvedAt": null,
      "deprecated": false
