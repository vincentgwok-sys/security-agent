{
  "skillId": "SEC-K8S-CTX-002",
  "skillName": "敏感挂载与文件系统滥用",
  "versionTimestamp": 1700000000000,
  "riskLevel": "HIGH",
  "description": "检测容器是否挂载了宿主机的敏感目录（如 /proc、/sys、Docker socket、宿主机根文件系统等），从而评估其数据泄露与容器逃逸风险。",
  "evolutionCount": 0,
  "reportMetadata": {
    "remediationFocus": "指导用户在 Kubernetes Pod 中正确配置 volumeMounts，避免将敏感宿主机路径挂载到容器内部；对 Docker socket 的访问应严格限制。"
  },
  "executionContexts": [
    {
      "contextId": "linux-debian-ubuntu-standard",
      "environmentFingerprint": {
        "osType": "linux",
        "osFlavors": [
          "debian",
          "ubuntu"
        ],
        "shellType": "bash",
        "requiredTools": [
          "mount",
          "cat",
          "df",
          "find",
          "grep"
        ],
        "optionalTools": [
          "lsblk",
          "stat",
          "readlink",
          "fdisk"
        ],
        "minKernelVersion": "3.10.0",
        "arch": [
          "amd64",
          "arm64"
        ]
      },
      "envCheckCommands": [
        "uname -s",
        "cat /etc/os-release 2>/dev/null | grep -E '^ID=|^VERSION_ID=' | head -3",
        "which mount cat df find grep lsblk stat readlink 2>/dev/null",
        "echo $SHELL",
        "uname -r",
        "uname -m"
      ],
      "executionLogic": {
        "expectedBehavior": "【判定硬规则】① mount输出中发现 docker.sock/containerd.sock=/host=/rootfs 异常挂载=FAIL。② find 找到 docker.sock/containerd.sock=FAIL。③ /proc/1/cgroup 显示 '/' 或空=FAIL。④ df -h 显示的设备容量不代表容器可访问的数据量。K8s 标准 bind-mount（/etc/hosts, /etc/hostname, /etc/resolv.conf, /dev/termination-log）底层可能是大容量宿主机卷，但容器仅可见单个文本文件，必须判 PASS！⑤ exit=127=工具不存在=PASS。⑥ mount/cat/proc 的 Permission denied 是正常现象(PASS)。 CCE explicitly forbids mounting: /, /boot, /dev, /etc, /lib, /proc, /sys, /usr.  Any mount matching these paths = FAIL. ",
        "detectionCommands": [
          "mount 2>&1 | grep -E 'docker.sock|containerd.sock|/host|/rootfs|/proc|/sys/fs/cgroup' | head -10",
          "cat /proc/1/mounts 2>&1 | grep -E '/proc|/sys|/etc/kubernetes|/var/lib/kubelet|/var/lib/docker' | head -10",
          "ls -la /*.sock /var/run/*.sock /run/*.sock 2>&1 | head -5",
          "find / -name 'docker.sock' -o -name 'containerd.sock' -type s 2>&1 | head -5",
          "cat /proc/self/cgroup 2>&1 | head -5",
          "df -h 2>&1 | grep -vE '^Filesystem|^tmpfs|^overlay|^/dev/loop|/etc/hosts|/etc/hostname|/etc/resolv.conf|/dev/termination-log|shm' | head -10; echo 'DF_SCAN_DONE'",
          "mount 2>&1 | grep -E 'on /(boot|dev|etc|lib|proc|sys|usr) ' | head -10; echo 'HOSTPATH_CHECK_DONE'"
        ]
      },
      "evolvedFrom": null,
      "evolvedAt": null,
      "deprecated": false
    },
