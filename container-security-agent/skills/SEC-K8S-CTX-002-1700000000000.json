{
  "skillId": "SEC-K8S-CTX-002",
  "skillName": "敏感挂载与文件系统滥用",
  "versionTimestamp": 1700000000000,
  "riskLevel": "HIGH",
  "description": "检测容器是否挂载了宿主机的敏感目录（如 /proc、/sys、Docker socket、宿主机根文件系统等），从而评估其数据泄露与容器逃逸风险。",
  "evolutionCount": 0,
  "reportMetadata": {
    "remediationFocus": "指导用户在 Kubernetes Pod 中正确配置 volumeMounts，避免将敏感宿主机路径挂载到容器内部；对 Docker socket 的访问应严格限制。"
  },
  "executionContexts": [
    {
      "contextId": "linux-debian-ubuntu-standard",
      "environmentFingerprint": {
        "osType": "linux",
        "osFlavors": ["debian", "ubuntu"],
        "shellType": "bash",
        "requiredTools": ["mount", "cat", "df", "find", "grep"],
        "optionalTools": ["lsblk", "stat", "readlink", "fdisk"],
        "minKernelVersion": "3.10.0",
        "arch": ["amd64", "arm64"]
      },
      "envCheckCommands": [
        "uname -s",
        "cat /etc/os-release 2>/dev/null | grep -E '^ID=|^VERSION_ID=' | head -3",
        "which mount cat df find grep lsblk stat readlink 2>/dev/null",
        "echo $SHELL",
        "uname -r",
        "uname -m"
      ],
      "executionLogic": {
        "expectedBehavior": "安全容器不应暴露宿主机文件系统。挂载点中不应出现 /var/run/docker.sock、/run/docker.sock、/run/containerd/containerd.sock、宿主机 /etc、/proc 或 /sys 的异常读写挂载。/proc/1/cgroup 应显示典型的容器 cgroup 路径（/docker/...、/kubepods/...），而非宿主机根 cgroup。特别注意 /proc/1/root 是否为符号链接到容器根（安全）还是宿主机根（危险）。",
        "detectionCommands": [
          "mount 2>&1 | grep -E 'docker.sock|containerd.sock|/host|/rootfs|/proc|/sys/fs/cgroup' | head -10",
          "cat /proc/1/mounts 2>&1 | grep -E '/proc|/sys|/etc/kubernetes|/var/lib/kubelet|/var/lib/docker' | head -10",
          "ls -la /*.sock /var/run/*.sock /run/*.sock 2>&1 | head -5",
          "find / -name 'docker.sock' -o -name 'containerd.sock' -type s 2>&1 | head -5",
          "cat /proc/self/cgroup 2>&1 | head -5",
          "df -h 2>&1 | grep -vE '^Filesystem|^tmpfs|^overlay|^/dev/loop' | head -10"
        ]
      },
      "evolvedFrom": null,
      "evolvedAt": null,
      "deprecated": false
    },
