{
  "skillId": "SEC-K8S-CTX-001",
  "skillName": "权限与隔离突破",
  "versionTimestamp": 1700000000000,
  "riskLevel": "CRITICAL",
  "description": "检测容器是否以 --privileged 模式运行，高危 Capability 是否存在，以及 cgroup/core_pattern/uevent_helper 等已知逃逸向量是否暴露。",
  "evolutionCount": 0,
  "reportMetadata": {
    "remediationFocus": "重点针对 Kubernetes Pod/Container 的 securityContext 进行加固，drop ALL capabilities、禁用特权模式、限制宿主机内核接口写入。"
  },
  "executionContexts": [
    {
      "contextId": "linux-debian-ubuntu-standard",
      "environmentFingerprint": {
        "osType": "linux",
        "osFlavors": ["debian", "ubuntu"],
        "shellType": "bash",
        "requiredTools": ["capsh", "cat", "mount", "grep", "test"],
        "optionalTools": ["getfattr", "attr", "nsenter", "unshare"],
        "minKernelVersion": "3.10.0",
        "arch": ["amd64", "arm64"]
      },
      "envCheckCommands": [
        "uname -s",
        "cat /etc/os-release 2>/dev/null | grep -E '^ID=|^VERSION_ID=' | head -3",
        "which capsh cat mount grep test nsenter unshare getfattr 2>/dev/null",
        "echo $SHELL",
        "uname -r",
        "uname -m",
        "id 2>&1"
      ],
      "executionLogic": {
        "expectedBehavior": "【判定硬规则】① exit=127=工具不存在=PASS(非漏洞)。② mount 失败+stderr含'Operation not permitted'/'Permission denied'/'必须以超级用户身份使用 mount'=PASS。③ mount 成功(exit=0)=FAIL。④ CapEff=ffffffff或含CAP_SYS_ADMIN(bit21)/CAP_SYS_PTRACE(bit19)=FAIL。⑤ Seccomp=2或1=PASS, Seccomp=0=FAIL。⑥ NoNewPrivs=1=PASS。⑦ cgroup/core_pattern/uevent_helper/module任一可写=FAIL(逃逸向量)。⑧ 发现块设备(/dev/sda等)=WARN(非必然FAIL)。⑨ uid=0+无user namespace=需关注。⑩ capsh --print中Current IAB含!cap_sys_admin等=PASS。",
        "detectionCommands": [
          "capsh --print 2>&1",
          "cat /proc/1/status 2>&1 | grep -E 'CapEff|Seccomp|NoNewPrivs'",
          "cat /proc/self/status 2>&1 | grep -E '^Uid:|^Gid:|CapEff|CapPrm|NoNewPrivs'",
          "mount -t tmpfs none /tmp/test_mount_csagent 2>&1; rmdir /tmp/test_mount_csagent 2>/dev/null; echo 'MOUNT_EXIT:'$?",
          "test -w /proc/sys/kernel/core_pattern && echo 'CORE_PATTERN_WRITABLE' || echo 'CORE_PATTERN_READONLY' 2>&1",
          "test -d /sys/fs/cgroup && test -w /sys/fs/cgroup && echo 'CGROUP_WRITABLE' || echo 'CGROUP_READONLY' 2>&1",
          "test -w /sys/kernel/uevent_helper && echo 'UEVENT_HELPER_WRITABLE' || echo 'UEVENT_HELPER_SAFE' 2>&1",
          "test -d /sys/module && test -w /sys/module && echo 'MODULE_WRITABLE' || echo 'MODULE_SAFE' 2>&1",
          "for dev in /dev/sda /dev/sdb /dev/vda /dev/vdb /dev/mem /dev/kmem /dev/port; do test -b $dev -o -c $dev && echo 'DEV_EXPOSED:'$dev; done 2>&1",
          "cat /proc/sys/kernel/unprivileged_userns_clone 2>&1; cat /proc/sys/user/max_user_namespaces 2>&1; echo 'USRNS_INFO_ONLY'"
        ]
      },
      "evolvedFrom": null,
      "evolvedAt": null,
      "deprecated": false
    },
