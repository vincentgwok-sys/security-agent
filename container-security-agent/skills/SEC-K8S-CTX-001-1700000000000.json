          "powershell.exe -Command \"Get-Process -IncludeUserName | Select-Object -First 10 | Format-List\"",
          "powershell.exe -Command \"whoami /priv | findstr /I 'SeDebugPrivilege SeTakeOwnershipPrivilege SeRestorePrivilege SeBackupPrivilege'\"",
          "reg query \"HKLM\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Isolation\" 2>&1"
        ]
