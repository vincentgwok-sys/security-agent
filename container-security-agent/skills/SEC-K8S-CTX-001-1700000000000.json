        "which cat grep mount capsh 2>/dev/null",
        "echo $SHELL",
        "uname -r",
        "uname -m",
        "id 2>&1"
      ],
      "executionLogic": {
        "expectedBehavior": "Alpine 容器安全标准同 Debian。特权操作应被拒绝，进程 CapEff 掩码不应含特权位。Alpine 的 BusyBox mount 可能行为略有不同，尤其注意 tmpfs 挂载是否被允许。Alpine 的 capsh 可能不可用，若缺失则从 /proc 读取 CapEff 代替。",
        "detectionCommands": [
          "cat /proc/1/status 2>&1 | grep -E 'CapEff|Seccomp|NoNewPrivs'",
          "mount -t tmpfs none /tmp/test_mount_csagent 2>&1; rmdir /tmp/test_mount_csagent 2>/dev/null; echo 'MOUNT_EXIT:'$?",
          "cat /proc/self/mounts 2>&1 | grep -E '/proc|/sys' | head -5",
          "cat /proc/self/status 2>&1 | grep -E '^Uid:|CapEff|NoNewPrivs'"
        ]
      },
