      "executionLogic": {
        "expectedBehavior": "【判定硬规则——必须遵守】① 绝对禁止用 wget 做任何连通性检测。wget -qO- 在连接失败时仍可能返回退出码 0（已知缺陷，已造成多次误报）。EVOLVE 时绝对不得将 curl 替换为 wget，若 curl 不可用则直接标记 PASS（工具缺失，非安全缺陷）。② curl 退出码含义：exit=0+有内容=危险（元数据可读）；exit=6=DNS失败(PASS)；exit=7=连接被拒(PASS)；exit=28=超时(PASS)；exit=127=curl不存在(PASS)。③ exit=127=工具不存在=PASS；exit=1或2+i操作被拒绝(Operation not permitted)=PASS。④ 高危信号（FAIL）：curl 成功读取元数据且输出非空；ip route add 成功执行。ss -tlnp 仅作信息收集不做判定。",

        "detectionCommands": [
          "ip route show 2>&1 | head -10",
          "cat /etc/resolv.conf 2>&1",
          "iptables -L INPUT 2>&1 | head -10; echo 'IPTABLES_EXIT:'$?",
          "iptables -A INPUT -j DROP 2>&1; echo 'IPTABLES_MODIFY_EXIT:'$?",
          "curl --connect-timeout 3 -sk https://kubernetes.default.svc.cluster.local 2>&1 | head -5; echo 'K8S_API_EXIT:'$?",
          "curl --connect-timeout 3 -s http://169.254.169.254/latest/meta-data/ 2>&1 | head -5; echo 'METADATA_EXIT:'$?",
          "ss -tlnp 2>&1 | head -10",
          "ip neigh show 2>&1 | head -10",
          "getent hosts google.com 2>&1; echo 'DNS_EXIT:'$?"
        ]
      },
