  "skillName": "网络隔离与横向移动",
  "versionTimestamp": 1700000000000,
  "riskLevel": "HIGH",
  "description": "检测容器是否具备修改网络配置（iptables、路由表）的权限，以及能否访问云元数据服务（169.254.169.254）、Kubernetes API Server、集群内其他 Service 等，评估其横向移动风险。",
  "evolutionCount": 0,
  "reportMetadata": {
    "remediationFocus": "指导用户配置 Kubernetes NetworkPolicy 实现微隔离，结合 CNI 插件（如 Calico、Cilium）限制 Pod 间通信；必要时启用 Pod Security Standards 限制容器网络能力。"
  },
  "executionContexts": [
    {
      "contextId": "linux-debian-ubuntu-standard",
      "environmentFingerprint": {
        "osType": "linux",
        "osFlavors": ["debian", "ubuntu"],
        "shellType": "bash",
        "requiredTools": ["cat", "grep", "ip", "curl"],
        "optionalTools": ["iptables", "nft", "wget", "ss", "host", "dig", "getent", "nslookup", "nmap", "tcpdump", "netcat"],
        "minKernelVersion": "3.10.0",
        "arch": ["amd64", "arm64"]
      },
      "envCheckCommands": [
        "uname -s",
        "cat /etc/os-release 2>/dev/null | grep -E '^ID=|^VERSION_ID=' | head -3",
        "which iptables nft ip curl wget ss host dig getent nslookup nmap nc 2>/dev/null",
        "echo $SHELL",
        "uname -r",
        "uname -m"
      ],
      "executionLogic": {
        "expectedBehavior": "安全容器中网络隔离正常时：iptables/nft 规则修改被拒绝（Operation not permitted 或 Permission denied）；云元数据端点 169.254.169.254 不可达（curl exit=7 连接被拒或 exit=28 超时）；Kubernetes API Server 和集群内 Service 不可达（curl exit=6 DNS 解析失败，或 exit=28 连接超时）；DNS 解析可能成功但 TCP 连接被 NetworkPolicy 阻断；进程不应监听 0.0.0.0 的非预期端口。高危信号：iptables 修改成功、元数据可读、API Server 可访问、可监听监听任意端口、可嗅探 ARP 或网络流量。注意：wget -qO- 在连接失败时可能仍返回退出码 0（不可靠，已知问题），curl --connect-timeout 必须用于连通性检测，需显式捕获退出码。nslookup 在部分容器中不可用，应优先使用 getent hosts 或 host 命令做 DNS 检测。",
        "detectionCommands": [
          "ip route show 2>&1 | head -10",
          "cat /etc/resolv.conf 2>&1",
          "iptables -L INPUT 2>&1 | head -10; echo 'IPTABLES_EXIT:'$?",
          "iptables -A INPUT -j DROP 2>&1; echo 'IPTABLES_MODIFY_EXIT:'$?",
          "curl --connect-timeout 3 -sk https://kubernetes.default.svc.cluster.local 2>&1 | head -5; echo 'K8S_API_EXIT:'$?",
          "curl --connect-timeout 3 -s http://169.254.169.254/latest/meta-data/ 2>&1 | head -5; echo 'METADATA_EXIT:'$?",
          "ss -tlnp 2>&1 | head -10",
          "ip neigh show 2>&1 | head -10",
          "getent hosts google.com 2>&1; echo 'DNS_EXIT:'$?"
        ]
      },
      "evolvedFrom": null,
      "evolvedAt": null,
      "deprecated": false
    },
