      "executionLogic": {
        "expectedBehavior": "安全容器中：iptables 修改返回 'Operation not permitted'；云元数据端点 169.254.169.254 不可达（curl 返回退出码 7 或 28）；Kubernetes API Server 访问被 CNI 阻断（连接超时或拒绝）；DNS 解析可能成功但 TCP 连接被 NetworkPolicy 阻断。不安全容器中：iptables 修改成功、云元数据可读取、API Server 可访问、可监听或嗅探网络流量。注意：wget -qO- 在连接失败时可能仍返回退出码 0（不可靠），应优先使用 curl --connect-timeout 进行连通性检测。",
        "detectionCommands": [
          "iptables -L INPUT 2>&1 | head -10",
          "iptables -A INPUT -j DROP 2>&1; echo 'EXIT_CODE:'$?",
          "ip route show 2>&1 | head -10",
          "cat /etc/resolv.conf 2>&1",
          "nslookup kubernetes.default.svc.cluster.local 2>&1",
          "curl --connect-timeout 3 -sk https://kubernetes.default.svc.cluster.local 2>&1 | head -5; echo 'EXIT_CODE:'$?",
          "curl --connect-timeout 3 -s http://169.254.169.254/latest/meta-data/ 2>&1 | head -5; echo 'EXIT_CODE:'$?",
          "ss -tlnp 2>&1 | head -10",
          "ip neigh show 2>&1 | head -10"
        ]
      },
